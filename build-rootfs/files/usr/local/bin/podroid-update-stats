#!/bin/sh
# Write Podman container count for the Android app (Downloads/Podroid/container-count).
set -eu

count=0
if command -v podman >/dev/null 2>&1; then
	count="$(podman ps -aq 2>/dev/null | wc -l | tr -d ' ')"
fi

mkdir -p /var/lib/podroid
printf '%s\n' "$count" > /var/lib/podroid/container-count

if mountpoint -q /mnt/downloads 2>/dev/null; then
	mkdir -p /mnt/downloads/Podroid
	printf '%s\n' "$count" > /mnt/downloads/Podroid/container-count
fi
